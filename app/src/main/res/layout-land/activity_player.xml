<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_gradient"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="360dp"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_down"
                app:tint="@color/text_primary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/playerHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/player_now_playing"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/btnClose"
                app:layout_constraintEnd_toStartOf="@id/btnPlayerMenu"
                app:layout_constraintTop_toTopOf="@id/btnClose"
                app:layout_constraintBottom_toBottomOf="@id/btnClose" />

            <ImageButton
                android:id="@+id/btnPlayerMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                app:tint="@color/text_primary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Artwork a sinistra -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/artworkBig"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MusicMood.LargeCover"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toBottomOf="@id/btnClose"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintWidth_percent="0.42" />

            <!-- Info + controlli a destra -->
            <TextView
                android:id="@+id/songTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/btnClose"
                app:layout_constraintStart_toEndOf="@id/artworkBig"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/songArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                app:layout_constraintTop_toBottomOf="@id/songTitle"
                app:layout_constraintStart_toStartOf="@id/songTitle"
                app:layout_constraintEnd_toEndOf="@id/songTitle" />

            <com.google.android.material.chip.Chip
                android:id="@+id/moodChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="#33FFFFFF"
                app:chipStrokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/songArtist"
                app:layout_constraintStart_toStartOf="@id/songTitle" />

            <com.google.android.material.slider.Slider
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:valueFrom="0"
                android:valueTo="1000"
                android:value="0"
                app:trackColorActive="@color/text_primary"
                app:trackColorInactive="#55FFFFFF"
                app:thumbColor="@color/text_primary"
                app:layout_constraintTop_toBottomOf="@id/moodChip"
                app:layout_constraintStart_toStartOf="@id/songTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/currentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/seekBar"
                app:layout_constraintTop_toBottomOf="@id/seekBar" />

            <TextView
                android:id="@+id/totalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@id/seekBar"
                app:layout_constraintTop_toBottomOf="@id/seekBar" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                app:tint="@color/text_primary"
                app:layout_constraintTop_toBottomOf="@id/currentTime"
                app:layout_constraintStart_toStartOf="@id/seekBar"
                app:layout_constraintEnd_toStartOf="@id/btnPlayPauseBig"
                app:layout_constraintHorizontal_chainStyle="packed" />

<com.google.android.material.floatingactionbutton.FloatingActionButton
    android:id="@+id/btnPlayPauseBig"
    android:layout_width="72dp"
    android:layout_height="72dp"
    android:layout_marginHorizontal="24dp"
    android:padding="0dp"
    android:scaleType="center"
    android:src="@drawable/ic_play"
    android:contentDescription="@string/player_play_pause"
    app:backgroundTint="@color/text_primary"
    app:tint="@color/dark_bg_top"
    app:fabCustomSize="72dp"
    app:maxImageSize="30dp"
    app:elevation="6dp"
    app:layout_constraintTop_toTopOf="@id/btnPrev"
    app:layout_constraintBottom_toBottomOf="@id/btnPrev"
    app:layout_constraintStart_toEndOf="@id/btnPrev"
    app:layout_constraintEnd_toStartOf="@id/btnNext" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/text_primary"
                app:layout_constraintTop_toTopOf="@id/btnPrev"
                app:layout_constraintBottom_toBottomOf="@id/btnPrev"
                app:layout_constraintStart_toEndOf="@id/btnPlayPauseBig"
                app:layout_constraintEnd_toEndOf="@id/seekBar" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
