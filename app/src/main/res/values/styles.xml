<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- BottomNavigationView dark, senza background bianco -->
    <style name="MusicMood.BottomNav"
        parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/dark_surface</item>
        <item name="itemIconTint">@color/text_secondary</item>
        <item name="itemTextColor">@color/text_secondary</item>
        <item name="itemActiveIndicatorStyle">@style/MusicMood.BottomNav.Indicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="MusicMood.BottomNav.Indicator"
        parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_purple</item>
        <item name="android:width">64dp</item>
        <item name="android:height">32dp</item>
    </style>

    <!-- Card scura -->
    <style name="MusicMood.Card"
        parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/dark_card_bg</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Pulsante "primario" gradient-style (filled) -->
    <style name="MusicMood.Button.Primary"
        parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_purple</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>
